# Copy this file to .env and fill in your values
# On Render, set these as Environment Variables in the dashboard

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# Gmail SMTP (for order confirmation & verification emails)
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# App URL (your Vercel frontend URL once deployed)
APP_URL=https://your-app.vercel.app

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id

# Resend (optional - for reminder emails)
RESEND_API_KEY=your-resend-api-key
REMINDER_FROM_EMAIL=reminders@yourdomain.com

# Twilio (optional - for SMS/WhatsApp notifications)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_FROM=whatsapp:+1234567890
